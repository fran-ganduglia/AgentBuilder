{
  "name": "proyecto-amigos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "docker compose up -d litellm",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "worker": "node --env-file=.env.local --experimental-strip-types --experimental-loader ./scripts/ts-path-loader.mjs ./scripts/worker-service.ts",
    "worker:queue": "node --env-file=.env.local --experimental-strip-types --experimental-loader ./scripts/ts-path-loader.mjs ./scripts/worker-queue.ts",
    "worker:maintenance": "node --env-file=.env.local --experimental-strip-types --experimental-loader ./scripts/ts-path-loader.mjs ./scripts/worker-maintenance.ts",
    "workers:pause": "node --env-file=.env.local ./scripts/toggle-n8n-workflows.mjs deactivate",
    "workers:resume": "node --env-file=.env.local ./scripts/toggle-n8n-workflows.mjs activate",
    "test:ts": "node --env-file=.env.local --experimental-strip-types --experimental-loader ./scripts/ts-path-loader.mjs",
    "test:google-calendar": "npm run test:ts -- src/lib/chat/google-calendar-tool-planner.test.ts && npm run test:ts -- src/lib/integrations/google-calendar-agent-runtime.test.ts && npm run test:ts -- src/lib/chat/google-calendar-tool-orchestrator.test.ts && npm run test:ts -- src/lib/integrations/google-calendar-write-runtime.test.ts",
    "ci:verify": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "mammoth": "^1.11.0",
    "next": "^15.5.12",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
