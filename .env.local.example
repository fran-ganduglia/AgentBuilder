# Supabase - publicas (expuestas al browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - solo servidor (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# App - solo servidor
APP_BASE_URL=http://localhost:3000
INTEGRATION_SECRETS_ENCRYPTION_KEY=

# LiteLLM - solo servidor
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Redis - solo servidor
REDIS_URL=

# OpenAI - solo servidor (embeddings para RAG)
OPENAI_API_KEY=

# Providers - solo servidor (usadas por LiteLLM)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Worker auth / scheduling - solo servidor
CRON_SECRET=
WORKERS_ENABLED=true

# n8n (solo local, no va a Vercel)
N8N_ENCRYPTION_KEY=           # string random 32 chars — nunca rotar sin migrar credentials
N8N_BASIC_AUTH_USER=          # usuario para la UI de n8n
N8N_BASIC_AUTH_PASSWORD=      # contraseña para la UI de n8n
N8N_POSTGRES_PASSWORD=        # contraseña interna de Postgres de n8n

# Redis — forma split para n8n Queue Mode (derivar de REDIS_URL)
REDIS_HOST=                   # solo el hostname, sin protocolo
REDIS_PORT=6379
REDIS_PASSWORD=               # si Redis requiere auth

# Salesforce OAuth - solo servidor
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_OAUTH_SCOPES=api refresh_token
SALESFORCE_API_VERSION=v61.0
# HubSpot OAuth - solo servidor
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_OAUTH_SCOPES=crm.objects.contacts.read crm.objects.contacts.write crm.objects.companies.read crm.objects.companies.write crm.objects.deals.read crm.objects.deals.write crm.objects.owners.read crm.objects.tasks.write crm.objects.meetings.write

# n8n REST API - solo servidor (activa/desactiva workflows programáticamente)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# Google Workspace OAuth - solo servidor
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
